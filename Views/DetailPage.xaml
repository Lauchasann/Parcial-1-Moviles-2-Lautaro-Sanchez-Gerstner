<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Parcial1.Views.DetailPage">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label 
            Text="{Binding PostSeleccionado.Title}" 
            FontSize="20"
            FontAttributes="Bold" />

        <Label 
            Text="{Binding PostSeleccionado.Body}" 
            FontSize="14" />

    </VerticalStackLayout>

</ContentPage>